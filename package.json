{
  "name": "mungaru-homestays",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "tsc && vite build",
    "optimize:img": "node scripts/optimize-images.mjs",
    "gen:icons": "node scripts/generate-icons.mjs",
    "analyze": "vite build --mode analyze",
    "size": "size-limit"
  },
  "size-limit": [
    {
      "name": "Total JS (gzipped)",
      "path": "dist/assets/*.js",
      "limit": "180 KB"
    }
  ],
  "dependencies": {
    "framer-motion": "^11.11.9",
    "lenis": "^1.1.13",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@size-limit/file": "^12.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.35.1",
    "size-limit": "^12.1.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
